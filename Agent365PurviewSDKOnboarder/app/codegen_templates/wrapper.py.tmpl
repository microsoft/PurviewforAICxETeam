"""${AGENT_DISPLAY_NAME_DOC} -- Purview-governed agent wrapper.

Wraps a downstream LLM/agent call with Microsoft Purview governance via the
Microsoft Graph dataSecurityAndGovernance APIs. Mirrors the reference
``purview_governed_agent.py`` shipped with the SDK so a freshly onboarded
agent uses exactly the same surface (Graph endpoints + permissions) that
works end-to-end.

Pipeline per chat turn:

  user prompt
     v
  Graph ``protectionScopes/compute``   (per-user, cached by ETag)
     v
  Graph ``processContent``  for prompt (activity=uploadText, if scope matches)
     v
  [if not blocked] -> downstream LLM/agent call
     v
  Graph ``processContent``  for response (activity=downloadText, if scope matches)
     v
  Graph ``contentActivities`` audit (fire-and-forget when no scope matches)
     v
  Local audit.log JSONL append
     v
  return ChatResult

Generated by Agent SDK Onboarder.
"""
from __future__ import annotations

import json
import logging
import os
import threading
import uuid
from dataclasses import dataclass, field
from datetime import datetime, timezone
from typing import Any, Optional

import msal
import requests

from agent_observability import (
    chat_observability_scope,
    inference_observability_scope,
)

log = logging.getLogger("purview-wrapper")

# Microsoft Graph is the real Purview governance surface. The previously
# used ``api.purview-service.microsoft.com`` host has no SPN in any tenant
# and produced AADSTS500011 on every chat. Do NOT change this.
GRAPH = "https://graph.microsoft.com/v1.0"
GRAPH_SCOPE = ["https://graph.microsoft.com/.default"]


# ---- Errors -----------------------------------------------------------------
class PurviewError(Exception):
    """Base class for any Purview-side failure."""


class PurviewAuthError(PurviewError):
    """MSAL could not get a Graph token for the Entra app."""


class PurviewGraphError(PurviewError):
    """Microsoft Graph returned a non-2xx response."""

    def __init__(self, status: int, body: str):
        super().__init__(f"Graph {status}: {body}")
        self.status = status
        self.body = body


# ---- Config + result --------------------------------------------------------
@dataclass
class PurviewConfig:
    tenant_id: str
    client_id: str
    client_secret: str
    app_display_name: str
    app_version: str = "1.0.0"
    force_audit: bool = True

    @classmethod
    def from_env(cls) -> "PurviewConfig":
        try:
            return cls(
                tenant_id=os.environ["PURVIEW_TENANT_ID"],
                client_id=os.environ["PURVIEW_CLIENT_ID"],
                client_secret=os.environ["PURVIEW_CLIENT_SECRET"],
                app_display_name=os.environ.get("APP_DISPLAY_NAME", ${AGENT_DISPLAY_NAME_REPR}),
                app_version=os.environ.get("APP_VERSION", "1.0.0"),
                force_audit=os.environ.get("PURVIEW_FORCE_AUDIT", "1").lower() in ("1", "true", "yes", "on"),
            )
        except KeyError as missing:
            raise PurviewError(f"missing env var: {missing}") from None


@dataclass
class ChatResult:
    blocked: bool
    response: Optional[str]
    block_reason: Optional[str] = None
    policy_actions: list[dict] = field(default_factory=list)
    conversation_id: str = ""
    turn_number: int = 0


@dataclass
class _ScopeCacheEntry:
    etag: str
    scopes: list


# ---- Main wrapper -----------------------------------------------------------
class PurviewGovernedAgent:
    """Adds Microsoft Purview governance around any LLM call via Graph APIs."""

    def __init__(
        self,
        cfg: PurviewConfig,
        downstream_call,
        block_message: str = (
            "This request was blocked by your organization's "
            "data protection policy."
        ),
        request_timeout: float = 30.0,
    ):
        self.cfg = cfg
        self._downstream = downstream_call
        self._block_message = block_message
        self._timeout = request_timeout

        # Some adapters (e.g. AWS Bedrock Agents, where sessionId controls
        # server-side conversation memory) need the conversation_id passed
        # downstream so a single chat turn maps to a single Bedrock session.
        # Most adapters take just (prompt) -> str. We inspect the callable
        # signature once and pass the kwarg only when supported, so older
        # generated adapters keep working unchanged.
        try:
            import inspect as _inspect
            _sig = _inspect.signature(downstream_call)
            self._downstream_accepts_convid = (
                "conversation_id" in _sig.parameters
                or any(p.kind == _inspect.Parameter.VAR_KEYWORD
                       for p in _sig.parameters.values())
            )
        except (TypeError, ValueError):
            self._downstream_accepts_convid = False

        self._msal = msal.ConfidentialClientApplication(
            client_id=cfg.client_id,
            client_credential=cfg.client_secret,
            authority=f"https://login.microsoftonline.com/{cfg.tenant_id}",
        )
        self._scope_cache: dict[str, _ScopeCacheEntry] = {}
        self._scope_lock = threading.Lock()

        self._audit_path = os.environ.get(
            "PURVIEW_AUDIT_LOG",
            os.path.join(os.path.dirname(os.path.abspath(__file__)), "audit.log"),
        )
        self._audit_lock = threading.Lock()

    # ---- Local audit (JSONL) ----
    def _audit(self, event: str, **fields) -> None:
        record = {
            "ts": datetime.now(timezone.utc).isoformat(timespec="milliseconds").replace("+00:00", "Z"),
            "event": event,
            **fields,
        }
        try:
            with self._audit_lock:
                with open(self._audit_path, "a", encoding="utf-8") as fh:
                    fh.write(json.dumps(record, ensure_ascii=False) + "\n")
        except OSError as exc:
            log.warning("audit write failed: %s", exc)

    # ---- Public API ----
    def chat(
        self,
        *,
        user_id: str,
        prompt: str,
        conversation_id: Optional[str] = None,
        turn_number: int = 1,
        user_name: Optional[str] = None,
        user_email: Optional[str] = None,
        user_ip: Optional[str] = None,
    ) -> ChatResult:
        """One governed turn: prompt -> Purview -> agent -> Purview -> audit."""
        conv_id = conversation_id or str(uuid.uuid4())

        with chat_observability_scope(
            conversation_id=conv_id,
            user_id=user_id,
            user_name=user_name,
            user_email=user_email,
            user_ip=user_ip,
            prompt=prompt,
            channel_name="purview-governed-wrapper",
        ) as invoke_scope:
            result = self._chat_impl(
                user_id=user_id, prompt=prompt,
                conv_id=conv_id, turn_number=turn_number,
            )
            if invoke_scope is not None:
                try:
                    invoke_scope.record_response(result.response or "")
                except Exception as exc:  # noqa: BLE001
                    log.debug("agent365 record_response failed: %s", exc)
            return result

    # ---- Pipeline ----
    def _chat_impl(
        self,
        *,
        user_id: str,
        prompt: str,
        conv_id: str,
        turn_number: int,
    ) -> ChatResult:
        scopes, etag = self._get_scopes(user_id)

        # ---------- pre-flight: prompt ----------
        if self._needs_eval(scopes, "uploadText"):
            inline = self._is_inline(scopes, "uploadText")
            verdict = self._process_content(
                user_id=user_id, text=prompt,
                activity="uploadText",
                conversation_id=conv_id,
                sequence_number=turn_number * 2,
                etag=etag,
            )
            if inline and self._is_blocked(verdict):
                self._audit("chat_complete", user_id=user_id, conversation_id=conv_id,
                            turn=turn_number, blocked=True, block_stage="prompt",
                            prompt_preview=prompt[:200])
                return ChatResult(
                    blocked=True, response=self._block_message,
                    block_reason="prompt contained content blocked by policy",
                    policy_actions=verdict.get("policyActions", []),
                    conversation_id=conv_id, turn_number=turn_number,
                )
        elif self.cfg.force_audit:
            # No policy scope matches this app -> still emit an audit entry so
            # DSPM Activity Explorer shows the turn (matches the SDK's
            # "no applicable scopes" branch).
            self._record_activity(
                user_id=user_id, text=prompt,
                activity="uploadText",
                conversation_id=conv_id,
                sequence_number=turn_number * 2,
            )

        # ---------- LLM call ----------
        with inference_observability_scope(
            conversation_id=conv_id,
            prompt=prompt,
        ) as inference_scope:
            try:
                ai_response = (
                    self._downstream(prompt, conversation_id=conv_id)
                    if self._downstream_accepts_convid
                    else self._downstream(prompt)
                ) or ""
            except Exception as exc:
                self._audit("chat_complete", user_id=user_id, conversation_id=conv_id,
                            turn=turn_number, blocked=False, error=str(exc)[:500])
                raise
            if inference_scope is not None:
                try:
                    inference_scope.record_output_messages([ai_response])
                except Exception as exc:  # noqa: BLE001
                    log.debug("agent365 record_output_messages failed: %s", exc)

        # ---------- post-flight: response ----------
        if self._needs_eval(scopes, "downloadText"):
            inline = self._is_inline(scopes, "downloadText")
            verdict = self._process_content(
                user_id=user_id, text=ai_response,
                activity="downloadText",
                conversation_id=conv_id,
                sequence_number=turn_number * 2 + 1,
                etag=etag,
            )
            if inline and self._is_blocked(verdict):
                self._audit("chat_complete", user_id=user_id, conversation_id=conv_id,
                            turn=turn_number, blocked=True, block_stage="response",
                            prompt_preview=prompt[:200],
                            response_preview=ai_response[:200])
                return ChatResult(
                    blocked=True, response=self._block_message,
                    block_reason="AI response contained content blocked by policy",
                    policy_actions=verdict.get("policyActions", []),
                    conversation_id=conv_id, turn_number=turn_number,
                )
        elif self.cfg.force_audit:
            self._record_activity(
                user_id=user_id, text=ai_response,
                activity="downloadText",
                conversation_id=conv_id,
                sequence_number=turn_number * 2 + 1,
            )

        self._audit("chat_complete", user_id=user_id, conversation_id=conv_id,
                    turn=turn_number, blocked=False,
                    prompt_preview=prompt[:200],
                    response_preview=ai_response[:200])
        return ChatResult(
            blocked=False, response=ai_response,
            conversation_id=conv_id, turn_number=turn_number,
        )

    def invalidate_user(self, user_id: str) -> None:
        """Drop cached protection scopes for a single user (e.g. on 412 ETag)."""
        with self._scope_lock:
            self._scope_cache.pop(user_id, None)

    # ---- Graph helpers ----
    def _token(self) -> str:
        """Acquire a Graph application token (cached internally by MSAL)."""
        res = self._msal.acquire_token_for_client(scopes=GRAPH_SCOPE)
        if "access_token" not in res:
            raise PurviewAuthError(
                f"token failure: {res.get('error_description') or res}"
            )
        return res["access_token"]

    def _graph_headers(self, etag: Optional[str] = None) -> dict:
        h = {
            "Authorization": f"Bearer {self._token()}",
            "Content-Type":  "application/json",
        }
        if etag:
            h["If-None-Match"] = etag
        return h

    def _get_scopes(self, user_id: str) -> tuple[list, Optional[str]]:
        """Compute protection scopes for this user/app, caching by ETag."""
        with self._scope_lock:
            cached = self._scope_cache.get(user_id)

        url = f"{GRAPH}/users/{user_id}/dataSecurityAndGovernance/protectionScopes/compute"
        body = {
            "activities": "uploadText,downloadText",
            "locations": [{
                "@odata.type": "microsoft.graph.policyLocationApplication",
                "value": self.cfg.client_id,
            }],
        }
        try:
            r = requests.post(
                url,
                headers=self._graph_headers(etag=cached.etag if cached else None),
                json=body, timeout=self._timeout,
            )
        except requests.RequestException as exc:
            log.warning("protectionScopes transport error: %s", exc)
            self._audit("protection_scopes", user_id=user_id, error=str(exc)[:500])
            # Fail open: empty scope -> chat continues without DLP, audit-only.
            return [], None

        if r.status_code == 304 and cached:
            self._audit("protection_scopes", user_id=user_id, http_status=304,
                        scope_count=len(cached.scopes), etag=cached.etag,
                        cached=True)
            return cached.scopes, cached.etag
        if r.status_code != 200:
            self._audit("protection_scopes", user_id=user_id,
                        http_status=r.status_code, error=r.text[:500])
            raise PurviewGraphError(r.status_code, r.text)

        scopes = (r.json() or {}).get("value", []) or []
        etag = r.headers.get("ETag")
        with self._scope_lock:
            self._scope_cache[user_id] = _ScopeCacheEntry(etag=etag or "", scopes=scopes)
        self._audit("protection_scopes", user_id=user_id, http_status=r.status_code,
                    scope_count=len(scopes), etag=etag,
                    activities=[s.get("activities") for s in scopes])
        return scopes, etag

    @staticmethod
    def _needs_eval(scopes: list, activity: str) -> bool:
        return any(activity in (s.get("activities") or "") for s in scopes)

    @staticmethod
    def _is_inline(scopes: list, activity: str) -> bool:
        return any(
            activity in (s.get("activities") or "")
            and s.get("executionMode") == "evaluateInline"
            for s in scopes
        )

    @staticmethod
    def _is_blocked(verdict: dict) -> bool:
        for a in verdict.get("policyActions", []) or []:
            if a.get("action") in ("restrictAccess", "block"):
                return True
            if a.get("restrictionAction") == "block":
                return True
        return False

    def _conversation_metadata_entry(self, *, text: str, conversation_id: str,
                                     sequence_number: int) -> dict:
        now = (datetime.now(timezone.utc)
               .isoformat(timespec="seconds").replace("+00:00", "Z"))
        return {
            "@odata.type":   "microsoft.graph.processConversationMetadata",
            "identifier":    str(uuid.uuid4()),
            "content": {
                "@odata.type": "microsoft.graph.textContent",
                "data":        text,
            },
            "name":             f"{self.cfg.app_display_name} message",
            "correlationId":    conversation_id,
            "sequenceNumber":   sequence_number,
            "isTruncated":      False,
            "createdDateTime":  now,
            "modifiedDateTime": now,
        }

    def _process_content(
        self,
        *,
        user_id: str,
        text: str,
        activity: str,
        conversation_id: str,
        sequence_number: int,
        etag: Optional[str],
    ) -> dict:
        """POST to Graph processContent. Returns the verdict dict."""
        url = f"{GRAPH}/users/{user_id}/dataSecurityAndGovernance/processContent"
        body = {
            "contentToProcess": {
                "contentEntries": [self._conversation_metadata_entry(
                    text=text, conversation_id=conversation_id,
                    sequence_number=sequence_number,
                )],
                "activityMetadata":   {"activity": activity},
                "deviceMetadata":     {"deviceType": "Unmanaged"},
                "protectedAppMetadata": {
                    "name":    self.cfg.app_display_name,
                    "version": self.cfg.app_version,
                    "applicationLocation": {
                        "@odata.type": "microsoft.graph.policyLocationApplication",
                        "value":       self.cfg.client_id,
                    },
                },
                "integratedAppMetadata": {
                    "name":    self.cfg.app_display_name,
                    "version": self.cfg.app_version,
                },
            }
        }
        try:
            r = requests.post(url, headers=self._graph_headers(etag),
                              json=body, timeout=self._timeout)
        except requests.RequestException as exc:
            log.warning("processContent transport error: %s", exc)
            self._audit("process_content", user_id=user_id,
                        conversation_id=conversation_id, activity=activity,
                        content_length=len(text), error=str(exc)[:500])
            # Fail open so a Graph outage cannot break chat.
            return {}

        if r.status_code == 412:
            self._audit("process_content", user_id=user_id,
                        conversation_id=conversation_id, activity=activity,
                        http_status=412, etag_stale=True,
                        content_length=len(text))
            self.invalidate_user(user_id)
            raise PurviewGraphError(412, "ETag stale; scopes refreshed.")
        if r.status_code not in (200, 202, 204):
            self._audit("process_content", user_id=user_id,
                        conversation_id=conversation_id, activity=activity,
                        http_status=r.status_code,
                        content_length=len(text), error=r.text[:500])
            raise PurviewGraphError(r.status_code, r.text)
        try:
            verdict = r.json() if r.text else {}
        except ValueError:
            verdict = {}
        self._audit("process_content", user_id=user_id,
                    conversation_id=conversation_id, activity=activity,
                    http_status=r.status_code, content_length=len(text),
                    policy_actions=verdict.get("policyActions", []),
                    blocked=self._is_blocked(verdict))
        return verdict

    def _record_activity(
        self,
        *,
        user_id: str,
        text: str,
        activity: str,
        conversation_id: str,
        sequence_number: int,
    ) -> None:
        """Fire-and-forget audit when no protection scope matches this app."""
        url = f"{GRAPH}/users/{user_id}/dataSecurityAndGovernance/activities/contentActivities"
        body = {
            "contentMetadata": {
                "contentEntries": [self._conversation_metadata_entry(
                    text=text, conversation_id=conversation_id,
                    sequence_number=sequence_number,
                )],
                "activityMetadata":   {"activity": activity},
                "deviceMetadata":     {"deviceType": "Unmanaged"},
                "protectedAppMetadata": {
                    "name":    self.cfg.app_display_name,
                    "version": self.cfg.app_version,
                    "applicationLocation": {
                        "@odata.type": "microsoft.graph.policyLocationApplication",
                        "value":       self.cfg.client_id,
                    },
                },
                "integratedAppMetadata": {
                    "name":    self.cfg.app_display_name,
                    "version": self.cfg.app_version,
                },
            }
        }
        try:
            r = requests.post(url, headers=self._graph_headers(),
                              json=body, timeout=self._timeout)
        except Exception as exc:  # noqa: BLE001
            log.warning("contentActivities POST failed: %s", exc)
            self._audit("content_activity", user_id=user_id,
                        conversation_id=conversation_id, activity=activity,
                        content_length=len(text), error=str(exc)[:500])
            return

        if r.status_code in (200, 201, 202, 204):
            try:
                rec_id = r.json().get("id") if r.text else None
            except ValueError:
                rec_id = None
            self._audit("content_activity", user_id=user_id,
                        conversation_id=conversation_id, activity=activity,
                        http_status=r.status_code, content_length=len(text),
                        record_id=rec_id)
        else:
            log.warning("contentActivities non-2xx %s: %s",
                        r.status_code, r.text[:300])
            self._audit("content_activity", user_id=user_id,
                        conversation_id=conversation_id, activity=activity,
                        http_status=r.status_code, content_length=len(text),
                        error=r.text[:500])


# ---- Personalized subclass --------------------------------------------------
# Concrete agent class named after this agent. server.py imports this directly
# so tracebacks/logs show whose wrapper is running.
AGENT_NAME = ${AGENT_DISPLAY_NAME_REPR}


class ${AGENT_CLASS_NAME}(PurviewGovernedAgent):
    """${AGENT_DISPLAY_NAME_DOC} -- concrete Purview-governed agent wrapper.

    Behaves exactly like PurviewGovernedAgent; subclass exists so server.py
    binds to a name that reflects the user-defined agent.
    """

    def __repr__(self) -> str:  # pragma: no cover - cosmetic
        return f"<${AGENT_CLASS_NAME} display_name={AGENT_NAME!r}>"
