"""Downstream call adapter for Amazon Bedrock.

Generated by Agent SDK Onboarder.

Supports two distinct Bedrock products, switched by ``BEDROCK_MODE``:

  * ``BEDROCK_MODE=model`` (default) -- direct foundation-model invocation
    via the ``bedrock-runtime.Converse`` API. Works for any model family
    on Bedrock (Anthropic Claude, Meta Llama, Amazon Titan, Cohere,
    Mistral, ...) using whichever ``BEDROCK_MODEL_ID`` you point it at.

  * ``BEDROCK_MODE=agent`` -- invoke a deployed Bedrock Agent (the AWS
    Bedrock Agents product, with knowledge bases / action groups / agent
    aliases) via ``bedrock-agent-runtime.InvokeAgent``. Requires the
    agent ID, an agent alias ID, and uses the per-call ``conversation_id``
    as the Bedrock ``sessionId`` so multi-turn conversations preserve
    server-side context. ``BEDROCK_SESSION_ID``, if set in the .env,
    pins every chat to a single session (debug / single-user only).

Authentication for both modes: standard AWS credential chain via boto3.
Either set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (+ AWS_SESSION_TOKEN
if using temporary credentials) in the environment, or rely on an
attached IAM role / ``~/.aws/credentials`` profile.

IAM minimums:
  * model mode  -- caller principal needs ``bedrock:InvokeModel`` on the
    model (or inference-profile) ARN.
  * agent mode  -- caller principal needs ``bedrock:InvokeAgent`` on the
    agent alias ARN. The Bedrock Agent's own service role separately
    needs permission to invoke the underlying model and read KBs.
"""
from __future__ import annotations

import logging
import os
import uuid
from typing import Callable, Optional


log = logging.getLogger(__name__)


def _client_kwargs(region: str) -> dict:
    """Build boto3.client kwargs from env (region + optional inline creds).

    boto3's default credential chain (env vars -> ``~/.aws/credentials``
    -> IAM role) kicks in automatically when no inline keys are present.
    """
    access_key = os.environ.get("AWS_ACCESS_KEY_ID", "").strip()
    secret_key = os.environ.get("AWS_SECRET_ACCESS_KEY", "").strip()
    session_token = os.environ.get("AWS_SESSION_TOKEN", "").strip()
    kwargs: dict = {"region_name": region}
    if access_key and secret_key:
        kwargs["aws_access_key_id"] = access_key
        kwargs["aws_secret_access_key"] = secret_key
        if session_token:
            kwargs["aws_session_token"] = session_token
    return kwargs


def _explain_client_error(exc: "ClientError") -> str:  # noqa: F821 - forward ref
    """Map common boto3 ClientError codes to actionable, user-safe messages."""
    code = ""
    try:
        code = (exc.response.get("Error") or {}).get("Code", "") or ""
    except Exception:  # noqa: BLE001
        pass
    if code == "AccessDeniedException":
        return ("AWS Bedrock denied the request. Check that the caller "
                "principal has bedrock:InvokeModel (model mode) or "
                "bedrock:InvokeAgent (agent mode), and that model access "
                "is enabled in the Bedrock console for this region.")
    if code == "ResourceNotFoundException":
        return ("AWS Bedrock could not find the target resource. Verify "
                "the model ID / agent ID / alias ID is correct and exists "
                "in the configured region.")
    if code == "ValidationException":
        return (f"AWS Bedrock rejected the request as invalid: {exc}. "
                "If using an Anthropic model on on-demand throughput, "
                "your model ID may need a cross-region inference prefix "
                "such as 'us.anthropic.claude-...'.")
    if code in ("ThrottlingException", "ServiceQuotaExceededException"):
        return "AWS Bedrock is throttling. Retry after a short backoff."
    if code == "ModelNotReadyException":
        return ("The Bedrock model is still loading on-demand capacity. "
                "Retry shortly.")
    return f"AWS Bedrock call failed ({code or 'unknown'}): {exc}"


# ===== Mode: foundation model (Converse API) =====
def _build_model_call(region: str) -> Callable[..., str]:
    model_id = os.environ.get("BEDROCK_MODEL_ID", "").strip()
    if not model_id:
        raise RuntimeError(
            "Bedrock model mode requires BEDROCK_MODEL_ID "
            "(e.g. us.anthropic.claude-3-5-sonnet-20241022-v2:0)"
        )

    import boto3
    from botocore.config import Config
    from botocore.exceptions import ClientError

    cfg = Config(read_timeout=120, connect_timeout=10,
                 retries={"mode": "standard", "max_attempts": 3})
    client = boto3.client("bedrock-runtime", config=cfg, **_client_kwargs(region))

    def call(prompt: str, conversation_id: Optional[str] = None) -> str:  # noqa: ARG001
        try:
            resp = client.converse(
                modelId=model_id,
                messages=[
                    {"role": "user", "content": [{"text": prompt}]},
                ],
                inferenceConfig={"maxTokens": 1024, "temperature": 0.7},
            )
        except ClientError as exc:
            raise RuntimeError(_explain_client_error(exc)) from exc
        # Converse response: {"output":{"message":{"content":[{"text":"..."}]}}, ...}
        try:
            parts = resp["output"]["message"]["content"]
            texts = [p.get("text", "") for p in parts if isinstance(p, dict)]
            return "".join(t for t in texts if t).strip()
        except (KeyError, TypeError):
            return ""

    return call


# ===== Mode: deployed Bedrock Agent (InvokeAgent API) =====
def _build_agent_call(region: str) -> Callable[..., str]:
    agent_id = os.environ.get("BEDROCK_AGENT_ID", "").strip()
    alias_id = os.environ.get("BEDROCK_AGENT_ALIAS_ID", "").strip()
    if not agent_id or not alias_id:
        raise RuntimeError(
            "Bedrock agent mode requires BEDROCK_AGENT_ID and "
            "BEDROCK_AGENT_ALIAS_ID (find them under Bedrock console -> "
            "Agents -> <agent> -> Aliases)."
        )
    # Optional pin: a single sessionId for the whole wrapper lifetime.
    # If set, every chat turn shares one Bedrock session -- only useful
    # for single-user / debug scenarios. Leave blank to use the per-chat
    # conversation_id (correct multi-user behaviour).
    fixed_session = os.environ.get("BEDROCK_SESSION_ID", "").strip()
    enable_trace = os.environ.get("BEDROCK_ENABLE_TRACE", "").strip().lower() in (
        "1", "true", "yes", "on")

    import boto3
    from botocore.config import Config
    from botocore.exceptions import ClientError

    # Agents can take longer than direct model calls (knowledge base reads,
    # action groups, multi-step orchestration). Default 5 min read timeout.
    cfg = Config(read_timeout=300, connect_timeout=10,
                 retries={"mode": "standard", "max_attempts": 2})
    client = boto3.client("bedrock-agent-runtime", config=cfg, **_client_kwargs(region))

    def call(prompt: str, conversation_id: Optional[str] = None) -> str:
        # sessionId controls Bedrock's server-side conversation memory.
        # Use the per-chat conversation_id when available so multi-turn
        # conversations from different users do not bleed into each other.
        session_id = fixed_session or conversation_id or str(uuid.uuid4())
        try:
            resp = client.invoke_agent(
                agentId=agent_id,
                agentAliasId=alias_id,
                sessionId=session_id,
                inputText=prompt,
                enableTrace=enable_trace,
            )
        except ClientError as exc:
            raise RuntimeError(_explain_client_error(exc)) from exc

        # The response body is an EventStream. We collect text "chunk"
        # events; we explicitly bail on "returnControl" because it means
        # the agent is asking the application to execute an action group
        # tool call that this wrapper does not implement.
        text_chunks: list[str] = []
        try:
            for event in resp.get("completion", []) or []:
                if "chunk" in event:
                    raw = event["chunk"].get("bytes") or b""
                    try:
                        text_chunks.append(raw.decode("utf-8"))
                    except UnicodeDecodeError:
                        text_chunks.append(raw.decode("utf-8", errors="replace"))
                elif "returnControl" in event:
                    raise RuntimeError(
                        "Bedrock Agent returned control to the caller for "
                        "an action group tool call, but this wrapper does "
                        "not implement action-group fulfillment. Either "
                        "remove the action group from the agent, or extend "
                        "the adapter to handle returnControl events."
                    )
                elif "trace" in event and enable_trace:
                    # Server-side trace events. Log at debug level only.
                    # Never surface trace content to the user -- it can
                    # contain raw retrieval / orchestration details.
                    log.debug("bedrock-agent trace event received")
                # Other event types (files, internalServerException, etc.)
                # are ignored for the text-reply use case.
        except ClientError as exc:
            raise RuntimeError(_explain_client_error(exc)) from exc

        return "".join(text_chunks).strip()

    return call


def build_downstream_call() -> Callable[..., str]:
    region = os.environ.get("AWS_REGION", "").strip() or "us-east-1"
    mode = (os.environ.get("BEDROCK_MODE") or "model").strip().lower()
    if mode == "model":
        return _build_model_call(region)
    if mode == "agent":
        return _build_agent_call(region)
    raise RuntimeError(
        f"Unsupported BEDROCK_MODE={mode!r}. Use 'model' (Converse API) "
        "or 'agent' (deployed Bedrock Agent via InvokeAgent)."
    )
