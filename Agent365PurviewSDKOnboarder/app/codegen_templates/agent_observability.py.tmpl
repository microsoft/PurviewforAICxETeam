"""Defensive wrapper around the Microsoft Agent 365 Observability SDK.

If the SDK isn't installed (or fails to import) this module degrades to no-op
context managers so the rest of the app keeps working.

Generated by Agent SDK Onboarder.
"""
from __future__ import annotations

import contextlib
import logging
import os
import threading
from dataclasses import dataclass
from typing import Optional

log = logging.getLogger("agent_observability")

# ---- lazy import of the SDK ----
_SDK_AVAILABLE = False
_IMPORT_ERROR: Optional[str] = None
try:
    from microsoft_agents_a365.observability.core import configure as _a365_configure
    from microsoft_agents_a365.observability.core import is_configured as _a365_is_configured
    from microsoft_agents_a365.observability.core.exporters import Agent365ExporterOptions
    from microsoft_agents_a365.observability.core.scopes import (
        InvokeAgentScope, InferenceScope, BaggageBuilder,
    )
    from microsoft_agents_a365.observability.core.entities import (
        AgentDetails, Request, InferenceCallDetails, ServiceEndpoint,
    )
    from microsoft_agents_a365.observability.core.auth import get_observability_authentication_scope
    _SDK_AVAILABLE = True
except Exception as exc:  # noqa: BLE001
    _IMPORT_ERROR = repr(exc)


@dataclass
class ObservabilityConfig:
    tenant_id: str
    agent_id: str
    agent_name: str
    agent_description: str
    agent_version: str
    agent_blueprint_id: str
    provider_name: str = "custom"
    service_namespace: str = "agent-wrapper"


_CONFIG: Optional[ObservabilityConfig] = None
_CONFIGURED = False
_CONFIG_LOCK = threading.Lock()


def _build_token_resolver(tenant_id: str, client_id: str, client_secret: str):
    """Return a callable (tenant, agent) -> Optional[token] for Agent 365 ingestion."""
    import msal
    cca = msal.ConfidentialClientApplication(
        client_id=client_id,
        client_credential=client_secret,
        authority=f"https://login.microsoftonline.com/{tenant_id}",
    )
    scope_list = get_observability_authentication_scope() if _SDK_AVAILABLE else [
        "api://9b975845-388f-4429-889e-eab1ef63949c/.default"
    ]
    raw = scope_list[0]
    resource = raw.split("/Agent365.Observability.OtelWrite")[0]
    cc_scope = f"{resource}/.default"

    def resolve(_tenant: str, _agent: str) -> Optional[str]:
        try:
            result = cca.acquire_token_for_client(scopes=[cc_scope])
            if "access_token" in result:
                return result["access_token"]
            log.warning("agent365 token failed: %s", result.get("error_description") or result)
            return None
        except Exception as exc:  # noqa: BLE001
            log.warning("agent365 token resolver threw: %s", exc)
            return None
    return resolve


def configure_observability(
    cfg: ObservabilityConfig,
    tenant_id: str,
    client_id: str,
    client_secret: str,
) -> bool:
    """Wire up the SDK. Safe to call repeatedly; never raises."""
    global _CONFIG, _CONFIGURED
    if not _SDK_AVAILABLE:
        log.info("agent365 SDK not installed; observability disabled (%s)", _IMPORT_ERROR)
        return False

    with _CONFIG_LOCK:
        _CONFIG = cfg
        if _CONFIGURED and _a365_is_configured():
            return True
        if not os.environ.get("ENABLE_OBSERVABILITY") and not os.environ.get("ENABLE_A365_OBSERVABILITY"):
            os.environ["ENABLE_OBSERVABILITY"] = "true"
        try:
            token_resolver = _build_token_resolver(tenant_id, client_id, client_secret)
            opts = Agent365ExporterOptions(token_resolver=token_resolver)
            ok = _a365_configure(
                service_name=cfg.agent_name,
                service_namespace=cfg.service_namespace,
                exporter_options=opts,
            )
            _CONFIGURED = bool(ok)
            mode = ("agent365 ingestion"
                    if os.environ.get("ENABLE_A365_OBSERVABILITY_EXPORTER", "").lower() in ("true", "1", "yes", "on")
                    else "console")
            log.info("agent365 telemetry configured (export=%s)", mode)
            return _CONFIGURED
        except Exception as exc:  # noqa: BLE001
            log.warning("agent365 configure() failed: %s", exc)
            return False


def is_observability_ready() -> bool:
    return _CONFIGURED and _SDK_AVAILABLE


# ---- Context managers ----
@contextlib.contextmanager
def chat_observability_scope(**baggage):
    """Open an InvokeAgentScope around a full chat turn (no-op if SDK unavailable)."""
    if not is_observability_ready() or _CONFIG is None:
        yield None
        return
    try:
        bag = BaggageBuilder()
        for k, v in baggage.items():
            if v is None:
                continue
            try:
                bag.add(k, str(v))
            except Exception:
                pass
        agent = AgentDetails(
            id=_CONFIG.agent_id,
            name=_CONFIG.agent_name,
            description=_CONFIG.agent_description,
            version=_CONFIG.agent_version,
            provider_name=_CONFIG.provider_name,
            blueprint_id=_CONFIG.agent_blueprint_id,
        )
        req = Request(text=baggage.get("prompt") or "")
        with InvokeAgentScope.start(
            agent=agent, request=req, baggage=bag,
            tenant_id=_CONFIG.tenant_id,
        ) as scope:
            yield scope
    except Exception as exc:  # noqa: BLE001
        log.warning("InvokeAgentScope failed (continuing): %s", exc)
        yield None


@contextlib.contextmanager
def inference_observability_scope(
    *,
    model_name: str = "",
    request_text: str = "",
    conversation_id: Optional[str] = None,
    prompt: Optional[str] = None,
    model: Optional[str] = None,
    provider: Optional[str] = None,
    endpoint_hostname: str = "",
    endpoint_port: Optional[int] = None,
    thought_process: Optional[str] = None,
    **_extra,
):
    """Open an InferenceScope around a single LLM call (no-op if SDK unavailable).

    Accepts a permissive kwargs set so it tolerates the call shape used by the
    Purview-governed wrapper (conversation_id, prompt) as well as the simpler
    (model_name, request_text) form. Extra/unknown kwargs are ignored so the
    shim never raises TypeError on signature drift.
    """
    if not is_observability_ready() or _CONFIG is None:
        yield None
        return
    try:
        effective_model = model or model_name or "unknown"
        effective_text = request_text or prompt or ""
        details = InferenceCallDetails(
            model_name=effective_model,
            request_text=effective_text,
        )
        endpoint = ServiceEndpoint(
            name=provider or _CONFIG.provider_name,
            url=endpoint_hostname or "",
        )
        with InferenceScope.start(
            inference_call=details,
            service_endpoint=endpoint,
        ) as scope:
            yield scope
    except Exception as exc:  # noqa: BLE001
        log.warning("InferenceScope failed (continuing): %s", exc)
        yield None
