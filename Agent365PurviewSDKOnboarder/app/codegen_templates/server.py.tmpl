<script>
let convId = crypto.randomUUID();
let turn = 0;
let hasMessages = false;

function userInitials(u){
  const s = (u && (u.name || u.upn)) || '?';
  const parts = s.split(/[\\s@]+/).filter(Boolean);
  return ((parts[0]||'?')[0] + (parts[1]||'')[0]||'').toUpperCase();
}

async function refreshUser(){
  const r = await fetch('/me'); const u = await r.json();
  const box = document.getElementById('userBox');
  if(u && u.oid){
    box.innerHTML = `<div class='avatar'>${userInitials(u)}</div>` +
      `<div class='info'>Signed in as <b>${u.name||u.upn}</b></div>` +
      `<a class='btn secondary' href='/logout'>Sign out</a>`;
  } else {
    box.innerHTML = `<div class='avatar' style='background:#8A8A8A'>?</div>` +
      `<div class='info'>Not signed in</div>` +
      `<a class='btn' href='/login'>Sign in with Microsoft</a>`;
  }
}

function appendMsg(role, text, blocked){
  const log = document.getElementById('log');
  if(!hasMessages){ log.innerHTML = ''; hasMessages = true; }
  const wrap = document.createElement('div');
  wrap.className = 'msg ' + (blocked ? 'blocked' : (role==='user' ? 'user-msg' : 'agent-msg'));
  const av = document.createElement('div'); av.className = 'av';
  av.textContent = role==='user' ? 'U' : (blocked ? '!' : 'A');
  const bub = document.createElement('div'); bub.className = 'bubble';
  bub.textContent = text;
  wrap.appendChild(av); wrap.appendChild(bub);
  log.appendChild(wrap);
  log.scrollTop = log.scrollHeight;
}

function clearChat(){
  convId = crypto.randomUUID(); turn = 0; hasMessages = false;
  document.getElementById('log').innerHTML =
    "<div class='empty'>New conversation. Ask the agent a question below.</div>";
}

async function send(){
  const inp = document.getElementById('prompt');
  const txt = inp.value.trim(); if(!txt) return;
  turn += 1;
  appendMsg('user', txt, false);
  inp.value = '';
  try{
    const r = await fetch('/chat', {method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({prompt:txt, conversation_id:convId, turn_number:turn})});
    if(r.status === 401){ appendMsg('agent', 'Please sign in first.', true); return; }
    const j = await r.json();
    if(j.blocked){ appendMsg('agent', 'Blocked by Purview: ' + (j.block_reason || 'policy'), true); }
    else { appendMsg('agent', j.response || '(empty response)', false); }
  } catch(e){
    appendMsg('agent', 'Request failed: ' + (e && e.message || e), true);
  }
}

document.getElementById('prompt').addEventListener('keydown', e => { if(e.key==='Enter') send(); });
refreshUser();
</script>
</body></html>
"""


@app.get("/", response_class=HTMLResponse)
def index() -> str:
    return _INDEX_HTML
