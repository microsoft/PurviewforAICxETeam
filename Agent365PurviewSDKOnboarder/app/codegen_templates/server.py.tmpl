# ---- OAuth ----
@app.get("/login")
def login(request: Request) -> RedirectResponse:
    flow = _msal_app().initiate_auth_code_flow(scopes=GRAPH_SCOPES, redirect_uri=REDIRECT_URI)
    request.session["auth_flow"] = flow
    return RedirectResponse(flow["auth_uri"])


@app.get("/auth/callback")
def callback(request: Request) -> RedirectResponse:
    flow = request.session.pop("auth_flow", None)
    if not flow:
        raise HTTPException(400, "no auth flow in session; restart /login")
    result = _msal_app().acquire_token_by_auth_code_flow(flow, dict(request.query_params))
    if "error" in result:
        raise HTTPException(401, f"auth error: {result.get('error_description') or result.get('error')}")
    claims = result.get("id_token_claims", {})
    request.session["user"] = {
        "oid": claims.get("oid"),
        "name": claims.get("name"),
        "upn": claims.get("preferred_username"),
    }
    return RedirectResponse("/")


@app.get("/logout")
def logout(request: Request) -> RedirectResponse:
    request.session.clear()
    return RedirectResponse(
        f"{AUTHORITY}/oauth2/v2.0/logout?post_logout_redirect_uri=http://${SERVER_HOST}:${SERVER_PORT}/"
    )


def _current_user(request: Request) -> Optional[dict]:
    return request.session.get("user")


@app.get("/me")
def me(request: Request):
    return _current_user(request) or {"signedIn": False}


@app.get("/healthz")
def healthz():
    return {"ok": True, "a365_obs": is_observability_ready()}


# ---- Chat API ----
class ChatRequest(BaseModel):
    prompt: str
    conversation_id: Optional[str] = None
    turn_number: int = 1


class ChatResponse(BaseModel):
    blocked: bool
    response: Optional[str]
    block_reason: Optional[str] = None
    policy_actions: list[dict] = []
    conversation_id: str
    turn_number: int
    user_id: Optional[str] = None


@app.post("/chat", response_model=ChatResponse)
def chat(req: ChatRequest, request: Request) -> ChatResponse:
    if _agent is None:
        raise HTTPException(503, "agent not initialized")
    user = _current_user(request)
    if not user:
        raise HTTPException(401, "sign in at /login first")
    conv_id = req.conversation_id or str(uuid.uuid4())
    try:
        result = _agent.chat(
            user_id=user["oid"], prompt=req.prompt,
            conversation_id=conv_id, turn_number=req.turn_number,
            user_name=user.get("name"), user_email=user.get("upn"),
            user_ip=request.client.host if request.client else None,
        )
    except PurviewError as e:
        log.exception("purview error")
        raise HTTPException(502, f"purview: {e}") from e
    except Exception as e:  # noqa: BLE001
        log.exception("agent error")
        raise HTTPException(500, str(e)) from e
    return ChatResponse(
        blocked=result.blocked, response=result.response,
        block_reason=result.block_reason, policy_actions=result.policy_actions,
        conversation_id=conv_id, turn_number=req.turn_number, user_id=user["oid"],
    )


