# ---- Redact OAuth tokens / secrets from uvicorn access logs ----
# Uvicorn's default access logger writes the full request URL, which means
# the /auth/callback request would leak the OAuth authorization code,
# client_info JWT, state and session_state into .launch.log on disk.
# We install a logging filter on the uvicorn.access logger that scrubs
# the query string of any request to /auth/callback or any other path
# whose query string contains known-sensitive parameter names.
_SENSITIVE_QS_KEYS = {
    "code", "client_info", "state", "session_state",
    "id_token", "access_token", "refresh_token",
    "secret", "client_secret", "password", "token", "api_key",
}
_QS_REDACT_RE = re.compile(
    r"([?&](?:" + "|".join(_SENSITIVE_QS_KEYS) + r")=)[^&\s\"]+",
    re.IGNORECASE,
)
class _RedactSensitiveQS(logging.Filter):
    """Strip sensitive query-string values from uvicorn access log lines."""
    def filter(self, record: logging.LogRecord) -> bool:
        try:
            if record.args:
                record.args = tuple(
                    _QS_REDACT_RE.sub(r"\1<REDACTED>", str(a)) if isinstance(a, str) else a
                    for a in record.args
                )
            if isinstance(record.msg, str):
                record.msg = _QS_REDACT_RE.sub(r"\1<REDACTED>", record.msg)
        except Exception:
            pass
        return True
# Attach to BOTH possible access loggers (some uvicorn versions use
# "uvicorn.access", others propagate through "uvicorn"). Adding twice is
# safe because logging.Filter dedupes on identity? No -- we guard with a
# sentinel attribute so re-imports don't stack filters.
def _install_qs_redactor() -> None:
    for name in ("uvicorn.access", "uvicorn"):
        lg = logging.getLogger(name)
        if getattr(lg, "_qs_redactor_installed", False):
            continue
        lg.addFilter(_RedactSensitiveQS())
        lg._qs_redactor_installed = True  # type: ignore[attr-defined]
_install_qs_redactor()


