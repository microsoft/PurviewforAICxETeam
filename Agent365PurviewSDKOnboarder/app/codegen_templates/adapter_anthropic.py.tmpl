"""Downstream call adapter for the Anthropic API (Claude direct).

Generated by Agent SDK Onboarder.

Uses the official `anthropic` SDK. For Claude on Bedrock or Claude on
Vertex AI, choose the Bedrock / Vertex provider instead -- those have
their own auth + endpoint shapes.
"""
from __future__ import annotations

import os
from typing import Callable


def build_downstream_call() -> Callable[[str], str]:
    model = (
        os.environ.get("ANTHROPIC_MODEL", "").strip()
        or "claude-3-5-sonnet-20241022"
    )
    api_key = os.environ.get("ANTHROPIC_API_KEY", "").strip()
    base_url = os.environ.get("ANTHROPIC_BASE_URL", "").strip()
    if not api_key:
        raise RuntimeError("Anthropic provider requires ANTHROPIC_API_KEY")

    from anthropic import Anthropic

    client_kwargs: dict = {"api_key": api_key}
    if base_url:
        client_kwargs["base_url"] = base_url
    client = Anthropic(**client_kwargs)

    def call(prompt: str) -> str:
        msg = client.messages.create(
            model=model,
            max_tokens=1024,
            messages=[{"role": "user", "content": prompt}],
        )
        # `content` is a list of TextBlock / ToolUseBlock; join the text ones.
        parts = []
        for block in msg.content or []:
            text = getattr(block, "text", None)
            if isinstance(text, str) and text:
                parts.append(text)
        return "".join(parts).strip()

    return call
