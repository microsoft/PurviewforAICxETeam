# ${AGENT_DISPLAY_NAME} â€” environment configuration
# Generated by Agent SDK Onboarder

# ===== Microsoft tenant / Purview governance SPN =====
PURVIEW_TENANT_ID=${TENANT_ID}
PURVIEW_CLIENT_ID=${CLIENT_ID}
PURVIEW_CLIENT_SECRET=${CLIENT_SECRET}

# Record activity to Purview audit even when content is blocked (recommended).
PURVIEW_FORCE_AUDIT=${FORCE_AUDIT}

# ===== Display metadata =====
APP_DISPLAY_NAME=${AGENT_DISPLAY_NAME}
APP_DESCRIPTION=${AGENT_DESCRIPTION}
APP_VERSION=1.0.0

# ===== HTTP server =====
SERVER_HOST=${SERVER_HOST}
SERVER_PORT=${SERVER_PORT}
# SESSION_SECRET is generated in-memory at agent startup (never written
# to disk) to honour the "no local secrets" rule. Set this var here only
# if you need stable sessions across restarts (e.g. production).
# SESSION_SECRET=

# ===== Agent 365 Observability (optional) =====
# Set to "true" to push OTel spans to Agent 365 ingestion (requires a 1st-party
# manager app -- otherwise leave false to keep spans in console mode).
ENABLE_A365_OBSERVABILITY_EXPORTER=false
ENABLE_OBSERVABILITY=${A365_ENABLED}

# ===== Provider-specific (only the section matching PROVIDER is used) =====
PROVIDER=${PROVIDER}

# Vertex AI
GCP_PROJECT=${VERTEX_PROJECT}
GCP_LOCATION=${VERTEX_LOCATION}
AGENT_RESOURCE_NAME=${VERTEX_RESOURCE_NAME}
GOOGLE_APPLICATION_CREDENTIALS=${VERTEX_ADC_PATH}

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=${AZURE_OPENAI_ENDPOINT}
AZURE_OPENAI_DEPLOYMENT=${AZURE_OPENAI_DEPLOYMENT}
AZURE_OPENAI_API_VERSION=${AZURE_OPENAI_API_VERSION}
AZURE_OPENAI_API_KEY=${AZURE_OPENAI_API_KEY}

# OpenAI public
OPENAI_MODEL=${OPENAI_MODEL}
OPENAI_API_KEY=${OPENAI_API_KEY}

# Custom HTTP
HTTP_URL=${HTTP_URL}
HTTP_METHOD=${HTTP_METHOD}
HTTP_PROMPT_FIELD=${HTTP_PROMPT_FIELD}
HTTP_RESPONSE_JSONPATH=${HTTP_RESPONSE_JSONPATH}
HTTP_AUTH_HEADER=${HTTP_AUTH_HEADER}

# Amazon Bedrock (foundation model via Converse API, OR deployed Agent via InvokeAgent)
AWS_REGION=${BEDROCK_REGION}
# BEDROCK_MODE: "model" (Converse, foundation model) or "agent" (deployed Bedrock Agent).
BEDROCK_MODE=${BEDROCK_MODE}
# Foundation-model mode:
BEDROCK_MODEL_ID=${BEDROCK_MODEL_ID}
# Deployed-Agent mode:
BEDROCK_AGENT_ID=${BEDROCK_AGENT_ID}
BEDROCK_AGENT_ALIAS_ID=${BEDROCK_AGENT_ALIAS_ID}
# Optional: pin a single Bedrock sessionId across every chat turn for
# this wrapper (debug / single-user only). Leave blank to use the
# per-chat conversation_id as the sessionId (correct multi-user).
BEDROCK_SESSION_ID=${BEDROCK_SESSION_ID}
# Optional: collect server-side trace events (logged only, never shown to user).
BEDROCK_ENABLE_TRACE=${BEDROCK_ENABLE_TRACE}
# Shared AWS credentials (leave blank to use boto3 default credential chain).
AWS_ACCESS_KEY_ID=${BEDROCK_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${BEDROCK_SECRET_ACCESS_KEY}
AWS_SESSION_TOKEN=${BEDROCK_SESSION_TOKEN}

# Anthropic Claude (direct API at api.anthropic.com)
ANTHROPIC_MODEL=${ANTHROPIC_MODEL}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
# Optional: override the API base, e.g. for an Anthropic-compatible proxy.
ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL}
