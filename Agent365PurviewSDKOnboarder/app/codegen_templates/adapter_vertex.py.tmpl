"""Downstream call adapter for Google Vertex AI Reasoning Engine / Agent Engine.

Generated by Agent SDK Onboarder.

Supports both modern ADK-style Agent Engine (`stream_query`) and older
reasoning engines (`query`). Authenticates via Application Default
Credentials (ADC) -- run `gcloud auth application-default login` or set
`GOOGLE_APPLICATION_CREDENTIALS` to a service-account key path.
"""
from __future__ import annotations

import os
from typing import Callable


def _extract_text(event: object) -> str:
    """Pull plain user-facing text out of one Vertex Agent Engine event/result.

    ADK / Agent Engine streams a mix of event types per turn:
      * `{content: {parts: [{text: "..."}]}}`           ← model reply  (USE)
      * `{actions: {state_delta: {...}}}`               ← sub-agent state update (SKIP)
      * `{actions: {transfer_to_agent: "..."}}`         ← delegation event (SKIP)
      * `{content: {parts: [{function_call: {...}}]}}`  ← tool call (SKIP)
      * `{content: {parts: [{function_response: {...}}]}}` ← tool result (SKIP)

    The wrapper must only surface model-authored text to the user; otherwise we'd
    leak raw repr() of the internal event dict into the chat UI. Events that
    don't carry user-facing text return "" so the caller can filter them out.
    """
    if event is None:
        return ""
    if isinstance(event, dict):
        content = event.get("content")
        if isinstance(content, dict):
            parts = content.get("parts") or []
            texts = [p.get("text", "") for p in parts
                     if isinstance(p, dict) and isinstance(p.get("text"), str)]
            joined = "".join(t for t in texts if t)
            if joined:
                return joined
        for key in ("output", "response", "text"):
            val = event.get(key)
            if isinstance(val, str) and val:
                return val
        # Dict with no recognized text-bearing field (state_delta, tool call,
        # transfer_to_agent, function_response, ...). Silent on purpose so the
        # raw event dict never leaks into the chat UI.
        return ""
    if isinstance(event, str):
        return event
    # Any other type (bytes, list, etc.) — silent to avoid leaking repr().
    return ""


def build_downstream_call() -> Callable[[str], str]:
    """Return a `prompt -> response` callable for the configured Vertex agent."""
    project = os.environ.get("GCP_PROJECT", "").strip()
    location = os.environ.get("GCP_LOCATION", "").strip() or "us-central1"
    resource = os.environ.get("AGENT_RESOURCE_NAME", "").strip()
    agent_user_id = os.environ.get("AGENT_USER_ID", "purview-governed-user").strip()
    if not (project and location and resource):
        raise RuntimeError(
            "Vertex provider requires GCP_PROJECT, GCP_LOCATION, AGENT_RESOURCE_NAME"
        )

    # vertexai is heavy, import lazily so the wrapper still starts without it.
    import vertexai
    from vertexai import agent_engines

    vertexai.init(project=project, location=location)
    engine = agent_engines.get(resource)

    has_stream_query = callable(getattr(engine, "stream_query", None))
    has_query = callable(getattr(engine, "query", None))

    def call(prompt: str) -> str:
        if has_stream_query:
            chunks = []
            for ev in engine.stream_query(message=prompt, user_id=agent_user_id):
                t = _extract_text(ev)
                if t:
                    chunks.append(t)
            reply = "".join(chunks).strip()
            if reply:
                return reply
            # Agent ran but produced no model text (e.g. only state updates or
            # tool calls). Tell the user instead of returning an empty bubble.
            return ("(the agent completed the turn but did not return a text "
                    "reply — it may have only updated internal state or called "
                    "a tool. Try rephrasing your question.)")
        if has_query:
            try:
                result = engine.query(input=prompt)
            except TypeError:
                result = engine.query(prompt=prompt)
            reply = _extract_text(result).strip()
            return reply or ("(the agent completed the turn but did not return "
                             "a text reply.)")
        raise RuntimeError(
            f"Agent {resource} exposes neither stream_query nor query"
        )

    return call
