{
  "compatibilityLevel": 1600,
  "model": {
    "annotations": [
      {
        "name": "PBI_QueryOrder",
        "value": "[\"Customers\",\"Policies\",\"UIComponents\",\"Licenses\",\"Trends\",\"AIAppsAgents\",\"KustoCluster\",\"KustoDatabase\"]"
      },
      {
        "name": "__PBI_TimeIntelligenceEnabled",
        "value": "0"
      },
      {
        "name": "PBI_ProTooling",
        "value": "[\"DevMode\"]"
      }
    ],
    "culture": "en-US",
    "dataAccessOptions": {
      "legacyRedirects": true,
      "returnErrorValuesAsNull": true
    },
    "defaultPowerBIDataSourceVersion": "powerBI_V3",
    "expressions": [
      {
        "name": "KustoCluster",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Text"
          }
        ],
        "expression": "\"https://cxedataplatformcluster.westus2.kusto.windows.net\" meta [IsParameterQuery=true, Type=\"Text\", IsParameterQueryRequired=true]",
        "kind": "m",
        "lineageTag": "k-cluster-param"
      },
      {
        "name": "KustoDatabase",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Text"
          }
        ],
        "expression": "\"cxedata\" meta [IsParameterQuery=true, Type=\"Text\", IsParameterQueryRequired=true]",
        "kind": "m",
        "lineageTag": "k-database-param"
      }
    ],
    "relationships": [
      {
        "name": "rel-aiapps-customers",
        "crossFilteringBehavior": "bothDirections",
        "fromColumn": "TenantId",
        "fromTable": "AIAppsAgents",
        "toColumn": "TenantId",
        "toTable": "Customers"
      }
    ],
    "sourceQueryCulture": "en-US",
    "tables": [
      {
        "name": "Customers",
        "columns": [
          {
            "name": "TenantId",
            "dataType": "string",
            "lineageTag": "col-tenantid",
            "sourceColumn": "TenantId"
          },
          {
            "name": "TenantName",
            "dataType": "string",
            "lineageTag": "col-tenantname",
            "sourceColumn": "TenantName"
          },
          {
            "name": "Sessions",
            "dataType": "int64",
            "lineageTag": "col-sessions",
            "sourceColumn": "Sessions",
            "summarizeBy": "sum"
          },
          {
            "name": "Policies",
            "dataType": "int64",
            "lineageTag": "col-policies",
            "sourceColumn": "Policies",
            "summarizeBy": "sum"
          },
          {
            "name": "E5PAU",
            "dataType": "int64",
            "lineageTag": "col-e5pau",
            "sourceColumn": "E5PAU",
            "summarizeBy": "sum"
          },
          {
            "name": "M365CopilotSeats",
            "dataType": "int64",
            "lineageTag": "col-copilotseats",
            "sourceColumn": "M365CopilotSeats",
            "summarizeBy": "sum"
          },
          {
            "name": "AIApps",
            "dataType": "int64",
            "lineageTag": "col-aiapps",
            "sourceColumn": "AIApps",
            "summarizeBy": "sum"
          },
          {
            "name": "AIAgents",
            "dataType": "int64",
            "lineageTag": "col-aiagents",
            "sourceColumn": "AIAgents",
            "summarizeBy": "sum"
          },
          {
            "name": "CustomerSegmentGroup",
            "dataType": "string",
            "lineageTag": "col-segment",
            "sourceColumn": "CustomerSegmentGroup"
          },
          {
            "name": "RegionName",
            "dataType": "string",
            "lineageTag": "col-region",
            "sourceColumn": "RegionName"
          },
          {
            "name": "IndustryName",
            "dataType": "string",
            "lineageTag": "col-industry",
            "sourceColumn": "IndustryName"
          },
          {
            "name": "HasM365Copilot",
            "dataType": "boolean",
            "lineageTag": "col-hascopilot",
            "sourceColumn": "HasM365Copilot"
          },
          {
            "name": "HasCopilotStudio",
            "dataType": "boolean",
            "lineageTag": "col-hascopilotstudio",
            "sourceColumn": "HasCopilotStudio"
          },
          {
            "name": "HasMIP",
            "dataType": "boolean",
            "lineageTag": "col-hasmip",
            "sourceColumn": "HasMIP"
          },
          {
            "name": "HasDLP",
            "dataType": "boolean",
            "lineageTag": "col-hasdlp",
            "sourceColumn": "HasDLP"
          },
          {
            "name": "IsDSPCAT",
            "dataType": "boolean",
            "lineageTag": "col-iscat",
            "sourceColumn": "IsDSPCAT"
          },
          {
            "name": "IsS500",
            "dataType": "boolean",
            "lineageTag": "col-iss500",
            "sourceColumn": "IsS500"
          },
          {
            "name": "IsF500",
            "dataType": "boolean",
            "lineageTag": "col-isf500",
            "sourceColumn": "IsF500"
          },
          {
            "name": "IsStrategicCustomer",
            "dataType": "boolean",
            "lineageTag": "col-isstrategic",
            "sourceColumn": "IsStrategicCustomer"
          },
          {
            "name": "AccountManager",
            "dataType": "string",
            "lineageTag": "col-acctmgr",
            "sourceColumn": "AccountManager"
          },
          {
            "name": "AccountTechnologyStrategist",
            "dataType": "string",
            "lineageTag": "col-ats",
            "sourceColumn": "AccountTechnologyStrategist"
          },
          {
            "name": "CountryName",
            "dataType": "string",
            "lineageTag": "col-country",
            "sourceColumn": "CountryName"
          },
          {
            "name": "SubSegmentName",
            "dataType": "string",
            "lineageTag": "col-subsegment",
            "sourceColumn": "SubSegmentName"
          }
        ],
        "lineageTag": "tbl-customers",
        "measures": [
          {
            "name": "Total Tenants",
            "expression": "COUNTROWS('Customers')",
            "lineageTag": "msr-totaltenants"
          },
          {
            "name": "Total Sessions",
            "expression": "SUM('Customers'[Sessions])",
            "lineageTag": "msr-totalsessions"
          },
          {
            "name": "Total E5 PAU",
            "expression": "SUM('Customers'[E5PAU])",
            "lineageTag": "msr-totale5pau"
          },
          {
            "name": "Total M365 Copilot Seats",
            "expression": "SUM('Customers'[M365CopilotSeats])",
            "lineageTag": "msr-totalcopilotseats"
          },
          {
            "name": "Total AI Apps",
            "expression": "SUM('Customers'[AIApps])",
            "lineageTag": "msr-totalaiapps"
          },
          {
            "name": "Total AI Agents",
            "expression": "SUM('Customers'[AIAgents])",
            "lineageTag": "msr-totalaiagents"
          },
          {
            "name": "Copilot Adoption %",
            "expression": "DIVIDE(CALCULATE(COUNTROWS('Customers'), 'Customers'[HasM365Copilot] = TRUE()), COUNTROWS('Customers'), 0) * 100",
            "formatString": "0.0\"%\"",
            "lineageTag": "msr-copilotpct"
          },
          {
            "name": "S500 Count",
            "expression": "CALCULATE(COUNTROWS('Customers'), 'Customers'[IsS500] = TRUE())",
            "lineageTag": "msr-s500count"
          },
          {
            "name": "CAT Count",
            "expression": "CALCULATE(COUNTROWS('Customers'), 'Customers'[IsDSPCAT] = TRUE())",
            "lineageTag": "msr-catcount"
          },
          {
            "name": "Avg Sessions per Tenant",
            "expression": "AVERAGE('Customers'[Sessions])",
            "formatString": "#,##0",
            "lineageTag": "msr-avgsessions"
          }
        ],
        "partitions": [
          {
            "name": "Customers-Partition",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = AzureDataExplorer.Contents(KustoCluster, KustoDatabase, \"",
                "let policies = Purview_FactAIHubEngagedAdmin",
                "| where Workload == 'AiHub' and Feature has 'DSPM for AI'",
                "| where SnapshotDate > ago(365d)",
                "| summarize Policies=dcount(Feature) by TenantId;",
                "let sessions = Purview_FactAIHubEngagedUsers",
                "| where Workload == 'AiHub'",
                "| where SnapshotDate > ago(365d)",
                "| summarize Sessions=sum(AllUp) by TenantId;",
                "let e5pau = FactTenantPAUBySKU",
                "| where SnapshotDate > ago(30d) and SkuName has 'E5' and HasPaidSeats == true",
                "| summarize E5PAU=sum(EXO) by TenantId;",
                "let copilotseats = FactTenantPAUBySKU",
                "| where SnapshotDate > ago(30d) and SkuName has 'Copilot' and HasPaidSeats == true",
                "| summarize M365CopilotSeats=sum(EXO) by TenantId;",
                "let copilotstudio = FactTenantPAUBySKU",
                "| where SnapshotDate > ago(30d) and SkuName has 'Copilot Studio'",
                "| summarize HasCopilotStudio=count() by TenantId;",
                "let aiapps = Purview_FactAIHubEngagedUsers",
                "| where Workload == 'AiHub' and Element == 'AllUp' and SubWorkload in ('AppsList','AgentsList')",
                "| where SnapshotDate > ago(365d)",
                "| summarize AIApps=sumif(AllUp, SubWorkload=='AppsList'), AIAgents=sumif(AllUp, SubWorkload=='AgentsList') by TenantId;",
                "let tenants = DimTenant",
                "| summarize arg_max(SnapshotDate, *) by TenantId;",
                "sessions",
                "| join kind=inner tenants on TenantId",
                "| join kind=leftouter policies on TenantId",
                "| join kind=leftouter e5pau on TenantId",
                "| join kind=leftouter copilotseats on TenantId",
                "| join kind=leftouter copilotstudio on TenantId",
                "| join kind=leftouter aiapps on TenantId",
                "| where TenantName !in~ ('ZAVA', 'ZAVA - PRIVATE', 'ONE MTC - PROD', 'P4AISDKFEB2025', 'XDRNINJAS', 'XDR NINJAS')",
                "| extend HasM365Copilot1 = iff(HasM365Copilot == 1, true, false)",
                "| extend HasMIP1 = iff(HasMIP == 1, true, false)",
                "| extend HasDLP1 = iff(HasDLP == 1, true, false)",
                "| extend IsDSPCAT1 = iff(IsDSPCAT == 1, true, false)",
                "| extend HasCopilotStudio1 = iff(isnotnull(HasCopilotStudio), true, false)",
                "| project TenantId, TenantName, Sessions, Policies=iff(isnull(Policies), tolong(0), Policies),",
                "    E5PAU=iff(isnull(E5PAU), tolong(0), E5PAU),",
                "    M365CopilotSeats=iff(isnull(M365CopilotSeats), tolong(0), M365CopilotSeats),",
                "    AIApps=iff(isnull(AIApps), tolong(0), AIApps),",
                "    AIAgents=iff(isnull(AIAgents), tolong(0), AIAgents),",
                "    CustomerSegmentGroup, SubSegmentName, RegionName, CountryName, IndustryName,",
                "    HasM365Copilot=HasM365Copilot1, HasCopilotStudio=HasCopilotStudio1, HasMIP=HasMIP1, HasDLP=HasDLP1,",
                "    IsDSPCAT=IsDSPCAT1, IsS500, IsF500, IsStrategicCustomer,",
                "    AccountManager, AccountTechnologyStrategist",
                "| order by Sessions desc\", [Timeout=#duration(0, 0, 10, 0)])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "Policies",
        "columns": [
          {
            "name": "Feature",
            "dataType": "string",
            "lineageTag": "col-pol-feature",
            "sourceColumn": "Feature"
          },
          {
            "name": "TenantCount",
            "dataType": "int64",
            "lineageTag": "col-pol-tenantcount",
            "sourceColumn": "TenantCount",
            "summarizeBy": "sum"
          }
        ],
        "lineageTag": "tbl-policies",
        "partitions": [
          {
            "name": "Policies-Partition",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = AzureDataExplorer.Contents(KustoCluster, KustoDatabase, \"",
                "Purview_FactAIHubEngagedAdmin",
                "| where Workload == 'AiHub' and Feature has 'DSPM for AI'",
                "| where SnapshotDate > ago(365d)",
                "| summarize TenantCount=dcount(TenantId) by Feature",
                "| order by TenantCount desc",
                "| take 20\", [Timeout=#duration(0, 0, 5, 0)])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "UIComponents",
        "columns": [
          {
            "name": "Page",
            "dataType": "string",
            "lineageTag": "col-ui-page",
            "sourceColumn": "Page"
          },
          {
            "name": "Users",
            "dataType": "int64",
            "lineageTag": "col-ui-users",
            "sourceColumn": "Users",
            "summarizeBy": "sum"
          }
        ],
        "lineageTag": "tbl-uicomponents",
        "partitions": [
          {
            "name": "UIComponents-Partition",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = AzureDataExplorer.Contents(KustoCluster, KustoDatabase, \"",
                "Purview_FactAIHubEngagedUsers",
                "| where Workload == 'AiHub' and Element == 'AllUp'",
                "| where SnapshotDate > ago(365d)",
                "| summarize Users=sum(AllUp) by Page",
                "| order by Users desc",
                "| take 15\", [Timeout=#duration(0, 0, 5, 0)])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "Licenses",
        "columns": [
          {
            "name": "SkuName",
            "dataType": "string",
            "lineageTag": "col-lic-sku",
            "sourceColumn": "SkuName"
          },
          {
            "name": "TenantCount",
            "dataType": "int64",
            "lineageTag": "col-lic-tenantcount",
            "sourceColumn": "TenantCount",
            "summarizeBy": "sum"
          },
          {
            "name": "TotalSeats",
            "dataType": "int64",
            "lineageTag": "col-lic-totalseats",
            "sourceColumn": "TotalSeats",
            "summarizeBy": "sum"
          }
        ],
        "lineageTag": "tbl-licenses",
        "partitions": [
          {
            "name": "Licenses-Partition",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = AzureDataExplorer.Contents(KustoCluster, KustoDatabase, \"",
                "let dspmTenants = Purview_FactAIHubEngagedAdmin",
                "| where Workload == 'AiHub' and Feature has 'DSPM for AI'",
                "| where SnapshotDate > ago(365d)",
                "| distinct TenantId;",
                "FactTenantPAUBySKU",
                "| where SnapshotDate > ago(30d)",
                "| where TenantId in (dspmTenants)",
                "| where SkuName has_any ('Copilot', 'E5', 'E3', 'Information Protection')",
                "| where HasPaidSeats == true",
                "| summarize TenantCount=dcount(TenantId), TotalSeats=sum(EXO) by SkuName",
                "| order by TenantCount desc",
                "| take 15\", [Timeout=#duration(0, 0, 5, 0)])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "Trends",
        "columns": [
          {
            "name": "Month",
            "dataType": "string",
            "lineageTag": "col-trend-month",
            "sourceColumn": "Month"
          },
          {
            "name": "Tenants",
            "dataType": "int64",
            "lineageTag": "col-trend-tenants",
            "sourceColumn": "Tenants",
            "summarizeBy": "sum"
          },
          {
            "name": "Sessions",
            "dataType": "int64",
            "lineageTag": "col-trend-sessions",
            "sourceColumn": "Sessions",
            "summarizeBy": "sum"
          }
        ],
        "lineageTag": "tbl-trends",
        "partitions": [
          {
            "name": "Trends-Partition",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = AzureDataExplorer.Contents(KustoCluster, KustoDatabase, \"",
                "Purview_FactAIHubEngagedUsers",
                "| where Workload == 'AiHub'",
                "| where SnapshotDate > ago(365d)",
                "| summarize Sessions=sum(AllUp), Tenants=dcount(TenantId) by Month=format_datetime(SnapshotDate, 'yyyy-MM')",
                "| order by Month asc\", [Timeout=#duration(0, 0, 5, 0)])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "AIAppsAgents",
        "columns": [
          {
            "name": "TenantId",
            "dataType": "string",
            "lineageTag": "col-aa-tenantid",
            "sourceColumn": "TenantId"
          },
          {
            "name": "SubWorkload",
            "dataType": "string",
            "lineageTag": "col-aa-subworkload",
            "sourceColumn": "SubWorkload"
          },
          {
            "name": "Page",
            "dataType": "string",
            "lineageTag": "col-aa-page",
            "sourceColumn": "Page"
          },
          {
            "name": "Interactions",
            "dataType": "int64",
            "lineageTag": "col-aa-interactions",
            "sourceColumn": "Interactions",
            "summarizeBy": "sum"
          }
        ],
        "lineageTag": "tbl-aiappsagents",
        "partitions": [
          {
            "name": "AIAppsAgents-Partition",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = AzureDataExplorer.Contents(KustoCluster, KustoDatabase, \"",
                "Purview_FactAIHubEngagedUsers",
                "| where Workload == 'AiHub' and SubWorkload in ('AppsList', 'AgentsList') and Element == 'AllUp'",
                "| where SnapshotDate > ago(365d)",
                "| summarize Interactions=sum(AllUp) by TenantId, SubWorkload, Page",
                "| order by Interactions desc",
                "| take 500\", [Timeout=#duration(0, 0, 5, 0)])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      }
    ]
  }
}